# =============================================
# Coderly Backend - Environment Variables
# Copy this file to .env and update the values
# =============================================

# --- Auth Service (PostgreSQL) ---
AUTH_DB_HOST=localhost
AUTH_DB_PORT=5432
AUTH_DB_USER=coderly
AUTH_DB_PASSWORD=your_password_here
AUTH_DB_NAME=coderly_auth
AUTH_GRPC_PORT=50051

# --- JWT ---
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRES_IN=7d

# --- Problem Service (MongoDB) ---
MONGO_URI=mongodb://localhost:27017/coderly_problems
PROBLEM_GRPC_PORT=50052

# --- Submission Service (PostgreSQL) ---
SUBMISSION_DB_HOST=localhost
SUBMISSION_DB_PORT=5432
SUBMISSION_DB_USER=coderly
SUBMISSION_DB_PASSWORD=your_password_here
SUBMISSION_DB_NAME=coderly_submissions
SUBMISSION_GRPC_PORT=50053

# --- Execution Engine ---
EXECUTION_GRPC_PORT=50054
DOCKER_SOCKET=/var/run/docker.sock
EXECUTION_TIMEOUT_MS=10000
EXECUTION_MEMORY_LIMIT_MB=256

# --- Redis (shared: sessions, BullMQ) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- API Gateway ---
GATEWAY_PORT=3000
