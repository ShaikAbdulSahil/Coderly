{
  "name": "coderly-backend",
  "version": "1.0.0",
  "description": "Coderly - A coding challenge platform with microservices architecture",
  "private": true,
  "scripts": {
    "build:auth": "cd apps/auth-service && npx tsc -p tsconfig.json",
    "build:problem": "cd apps/problem-service && npx tsc -p tsconfig.json",
    "build:submission": "cd apps/submission-service && npx tsc -p tsconfig.json",
    "build:execution": "cd apps/execution-engine && npx tsc -p tsconfig.json",
    "build:gateway": "cd apps/api-gateway && npx tsc -p tsconfig.json",
    "start:auth": "cd apps/auth-service && npx ts-node src/main.ts",
    "start:problem": "cd apps/problem-service && npx ts-node src/main.ts",
    "start:submission": "cd apps/submission-service && npx ts-node src/main.ts",
    "start:execution": "cd apps/execution-engine && npx ts-node src/main.ts",
    "start:gateway": "cd apps/api-gateway && npx ts-node src/main.ts",
    "start:dev:auth": "cd apps/auth-service && npx ts-node-dev --respawn src/main.ts",
    "start:dev:problem": "cd apps/problem-service && npx ts-node-dev --respawn src/main.ts",
    "start:dev:submission": "cd apps/submission-service && npx ts-node-dev --respawn src/main.ts",
    "start:dev:execution": "cd apps/execution-engine && npx ts-node-dev --respawn src/main.ts",
    "start:dev:gateway": "cd apps/api-gateway && npx ts-node-dev --respawn src/main.ts"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.10.0",
    "@grpc/proto-loader": "^0.7.12",
    "@nestjs/bullmq": "^10.1.0",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/microservices": "^10.3.0",
    "@nestjs/mongoose": "^10.0.4",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/platform-socket.io": "^10.3.0",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^10.3.0",
    "@types/ioredis": "^4.28.10",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.1.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dockerode": "^4.0.2",
    "ioredis": "^5.9.3",
    "mongoose": "^8.1.0",
    "pg": "^8.11.3",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/dockerode": "^3.3.23",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.10.9",
    "@types/uuid": "^9.0.7",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
